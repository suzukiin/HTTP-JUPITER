<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-4 pb-3 mb-4 border-bottom border-secondary border-opacity-25">
    <h1 class="h2">Dashboard <span class="text-muted fs-5 fw-light ms-2">| Visão Geral</span></h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-outline-secondary font-mono" onclick="fetchLogs()">Exportar Logs</button>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="dash-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h6 class="text-muted text-uppercase small mb-1">System Uptime</h6>
                    <h2 class="card-value mt-1 mb-0" id="uptime">--</h2>
                </div>
                <div class="p-2 bg-jupiter-subtle rounded-2">
                    <i class="bi bi-activity text-secondary fs-4"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="dash-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="text-muted text-uppercase small mb-0">Network Traffic</h6>
                <i class="bi bi-arrow-down-up text-jupiter"></i>
            </div>

            <div class="d-flex justify-content-between mb-1 font-mono small">
                <span class="text-muted">RX (Down)</span>
                <span class="text-light" id="download-traffic">--</span>
            </div>
            <div class="progress mb-3" style="height: 4px;">
                <div class="progress-bar bg-jupiter" style="width: 0%" id="download-traffic-progress"></div>
            </div>

            <div class="d-flex justify-content-between mb-1 font-mono small">
                <span class="text-muted">TX (Up)</span>
                <span class="text-light" id="upload-traffic">--</span>
            </div>
            <div class="progress" style="height: 4px;">
                <div class="progress-bar bg-info" style="width: 0%" id="upload-traffic-progress"></div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="h5 text-light mb-0 d-flex align-items-center">
        <i class="bi bi-speedometer2 me-2 text-secondary"></i> Telemetria em Tempo Real
    </h4>
    <span class="badge bg-dark border border-secondary text-secondary font-mono" id="telemetry-last-update">--</span>
</div>

<div id="telemetry-container" class="row g-4 mb-5">
    <div class="col-12 text-center text-muted py-5">
        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
        Aguardando dados dos equipamentos
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="h5 text-light mb-0 d-flex align-items-center">
        <i class="bi bi-terminal me-2 text-secondary"></i> Logs do Sistema
    </h4>
    </div>